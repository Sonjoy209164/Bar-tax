APP_NAME=bangla-tax-rag
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
CONFIG_PATH=config/config.dev.yaml
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
AGENTIC_STORE_DIR=data/agentic_store
SPARSE_INDEX_DIR=indexes/sparse
DENSE_INDEX_DIR=indexes/dense
RESULTS_DIR=results
TRACE_DIR=results/traces
UI_BACKEND_BASE_URL=http://127.0.0.1:8000
RETRIEVAL_MODE=hybrid
TOP_K=5
FINAL_EVIDENCE_K=3
GENERATOR_PROVIDER=openai_compatible
GENERATOR_MODEL_NAME=deepseek-r1:7b
GENERATOR_BASE_URL=http://127.0.0.1:11434/v1
MAX_GENERATION_TOKENS=512
TEMPERATURE=0.0
ABSTENTION_SCORE_THRESHOLD=0.75
VERIFICATION_ENABLED=true
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL_NAME=mock-dense-overlap
VECTOR_DB=local
LOCAL_VECTOR_STORE_PATH=data/agentic_store/local_vectors.jsonl
